{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,

  "name": "rhythmz/events-block",
  "title": "Events Block",

  "category": "text",
  "icon": "smiley",

  "supports": {
    "align": true
  },

  "attributes": {
    "align": { "type": "string", "default": "none" },
    "justify": { "type": "string", "default": "left" },
    "blockClassName": { "type": "string" },

    "events": {
      "type": "object",
      "default": {
        "styles": {
          "borderColor": "#333333"
        },
        "colors": {
          "bgColor": "#333333",
          "bgGradient": "",
          "textColor": "#333333",
          "headingColor": "#333333",
          "borderColor": "#333333",
          "borderGradient": ""
        },
        "show_vip_btn": true,
        "post_per_page": 10,
        "show_ticket_btn": true,

        "layout": "blog",
        "display": true,
        "blog": {
          "id": "",
          "styles": {},
          "ticket": true,
          "bookBtn": true,
          "limiter": 10,
          "gridOptions": {}
        },
        "carousel": {
          "id": "",
          "styles": {
            "bgColor": "red",
            "textColor": "blue",
            "accentColor": "yellow",
            "buttonColor": "orange",
            "paginationColor": "green",
            "ageBgColor": "purple"
          },
          "limiter": 5,
          "swiperOptions": {}
        }
      }
    },

    "slider": {
      "type": "object",
      "default": {
        "display": true,
        "fontSize": "12px",
        "minHeight": "100vh",
        "swiper": {
          "loop": true,
          "speed": 500,
          "effect": "slide",
          "parallax": false,
          "duration": 2,
          
          "autoplay": true,
          "autoplayDelay": 4200,
          "autoplayOnInteractions": false
        },
        "colors": {
          "sliderColor": "#ffffff",
          "sliderBackground": "#111111"
        },
        "navigation": {
          "size": "1.8rem",
          "display": true,
          "colors": {
            "navBg": "#111111",
            "navBgHover": "#111111",
            "navBgGradient": "",
            "navBgGradientHover": "",
            "navColor": "#ffffff",
            "navColorHover": "#ffffff"
          },
          "borders": {
            "linked": true,
            "top": {
              "width": "3px",
              "color": "#333333",
              "style": "solid"
            },
            "left": {
              "width": "3px",
              "color": "#333333",
              "style": "solid"
            },
            "right": {
              "width": "3px",
              "color": "#333333",
              "style": "solid"
            },
            "bottom": {
              "width": "3px",
              "color": "#333333",
              "style": "solid"
            }
          },
          "radius": {
            "linked": true,
            "topLeft": "100px",
            "topRight": "100px",
            "bottomLeft": "100px",
            "bottomRight": "100px"
          },
          "padding": {
            "linked": true,
            "top": "0px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
          }
        },
        "pagination": {
          "display": true,
          "markers": true,
          "fractions": true,
          "colors": {
            "separatorColor": "#ffffff",
            "pagColor": "#ffffff",
            "pagBg": "#111111",
            "pagHoverBg": "#111111",
            "pagActiveBg": "#32936F"
          },
          "borders": {
            "linked": true,
            "top": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "left": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "right": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "bottom": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            }
          },
          "radius": {
            "linked": true,
            "topLeft": "999px",
            "topRight": "999px",
            "bottomLeft": "999px",
            "bottomRight": "999px"
          },
          "padding": {
            "linked": true,
            "top": "0px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
          }
        },
        "autoplay": {
          "colors": {
            "autoplayBg": "rgb(100, 149, 237)",
            "autoplayColor": "#fffffff"
          },
          "borders": {
            "linked": true,
            "top": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "left": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "right": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            },
            "bottom": {
              "width": "none",
              "color": "#333333",
              "style": "solid"
            }
          },
          "radius": {
            "linked": true,
            "topLeft": "999px",
            "topRight": "999px",
            "bottomLeft": "999px",
            "bottomRight": "999px"
          },
          "padding": {
            "linked": true,
            "top": "0px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
          }
        },
        "borders": {
          "linked": true,
          "top": {
            "width": "none",
            "color": "#333333",
            "style": "solid"
          },
          "left": {
            "width": "none",
            "color": "#333333",
            "style": "solid"
          },
          "right": {
            "width": "none",
            "color": "#333333",
            "style": "solid"
          },
          "bottom": {
            "width": "none",
            "color": "#333333",
            "style": "solid"
          }
        },
        "radius": {
          "linked": true,
          "topLeft": "none",
          "topRight": "none",
          "bottomLeft": "none",
          "bottomRight": "none"
        }
      }
    },

    "slides": {
      "type": "object",
      "default": {
        "age": true,
        "date": true,
        "time": true,
        "title": true,
        "price": true,
        "poster": true,
        "excerpt": true,
        "layout": "centered",
        "display": false,
        "buttonOne": {
          "url": "rhythmzlounge.com/upcoming-events",
          "label": "Get Tickets",
          "display": true
        },
        "buttonTwo": {
          "url": "rhythmzlounge.com/reservations",
          "label": "The VIP Experience",
          "display": true
        },
        "otherSlides": [
          {
            "title": "Rhythmz",
            "tagline": "Omaha, NE",
            "excerpt": "",
            "mediaId": "",
            "mimeType": "video",
            "mediaSrc": "http://localhost/rhythmzlounge.com/wp-content/customs/video/home.mp4",
            "slideType": "other-slide",
            "buttonOne": {
              "url": "rhythmzlounge.com/upcoming-events",
              "label": "Get Tickets",
              "display": true
            },
            "buttonTwo": {
              "url": "rhythmzlounge.com/reservations",
              "label": "The VIP Experience",
              "display": true
            }
          }
        ],
        "colors": {
          "slideText": "#ffffff",
          "slideBackground": "#222222",
          "metaColor": "#444444",
          "overlayColor": "#ffffff",
          "accentColor": "#ffffff",
          "linkColor": "#ffffff",
          "linkBackground": "",
          "linkGradient": "",
          "linkColorHover": "#ffffff",
          "linkBackgroundHover": "#ffffff",
          "linkGradientHover": ""
        },
        "button": {
          "padding": {
            "linked": false,
            "top": "5px",
            "left": "18px",
            "right": "18px",
            "bottom": "5px"
          },
          "borders": {
            "linked": true,
            "top": {
              "width": "1px",
              "color": "#ffffff",
              "style": "solid"
            },
            "left": {
              "width": "1px",
              "color": "#ffffff",
              "style": "solid"
            },
            "right": {
              "width": "1px",
              "color": "#ffffff",
              "style": "solid"
            },
            "bottom": {
              "width": "1px",
              "color": "#ffffff",
              "style": "solid"
            }
          },
          "radius": {
            "linked": true,
            "topLeft": "999px",
            "topRight": "999px",
            "bottomLeft": "999px",
            "bottomRight": "999px"
          }
        },
        "radius": {"linked": true},
        "padding": {"linked": true},
        "borders": {"linked": true}
      }
    },

    "booking": {
      "type": "object",
      "defaults": {
        "color": "",
        "accent": "",
        "cartURL": "",
        "hover": {
          "text": "",
          "background": ""
        },
        "display": true,
        "background": ""
      }
    }
  },

  "editorStyle": [
    "file:./css/sidebar.css",
    "file:./css/slider.css",
    "file:./css/events.css",
    "file:./css/venue.map.css",
    "file:./css/events.blog.css",
    "file:./css/events.carousel.css",
    "file:./css/events.slider.css",
    "file:./css/edit.css",
    "file:../../assets/css/popup.css",
    "file:../../assets/css/date.picker.css",
    "file:./css/popup.tickets.css"
  ],
  "style": [
    "file:./css/slider.css",
    "file:./css/events.css",
    "file:./css/venue.map.css",
    "file:./css/events.blog.css",
    "file:./css/events.carousel.css",
    "file:./css/events.slider.css",
    "file:../../assets/css/popup.css",
    "file:../../assets/css/image.zoom.css",
    "file:../../assets/css/date.picker.css",
    "file:./css/popup.tickets.css",
    "file:./css/save.css"
  ],

  "script": ["file:./libs/controller.js"],
  "viewScript": ["file:./js/frontend.js"],
  "editorScript": ["file:./index.js"]
}
